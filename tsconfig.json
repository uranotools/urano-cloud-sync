{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["*"],
      "@models/*": ["*"],
      "@modules/*": ["*"]
    }
  },
  "include": ["config.ts", "Plugins/**/*.ts"]
}
